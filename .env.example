# Copy to `.env.local` for local development (never commit real secrets).

# PostgreSQL connection string (local Docker, Neon, etc.)
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/isits

# Better Auth — use a long random string in production (32+ characters)
BETTER_AUTH_SECRET=development-only-secret-min-32-characters!

# Public URL of the app (production: https://your-domain.com)
# BETTER_AUTH_URL=http://localhost:3000

# Optional: first manager seed (scripts/seed-manager.ts / db:seed)
# SEED_MANAGER_USERNAME=manager
# SEED_MANAGER_PASSWORD=ChangeMe123!
# SEED_MANAGER_NAME=System Manager
